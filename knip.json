{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "third-party/**",
    "scripts/**"
  ],
  "workspaces": {
    "packages/app": {
      "entry": "src/handlers/*/handler.ts"
    },
    "packages/infra": {
      "entry": "src/app.ts"
    },
    "packages/integration-tests": {
      "entry": "tests/**/*.test.ts"
    }
  }
}
