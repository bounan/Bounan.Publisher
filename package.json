{
  "name": "bounan-publisher",
  "private": true,
  "scripts": {
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "knip": "knip",
    "test": "vitest run --coverage --project app",
    "test:watch": "vitest --watch --project app",
    "test:ui": "vitest --ui --project app",
    "dependencies:check": "pnpm outdated --recursive --use-stderr",
    "dependencies:update": "pnpm update --recursive --latest",
    "licenses:scan": "pnpm licenses list --prod --json > thirdparty.json",
    "licenses:generate": "pnpm run -w licenses:scan && node scripts/format-thirdparty.mjs",
    "cdk:synth": "pnpm -r --filter infra cdk:synth",
    "cdk:diff": "pnpm -r --filter infra cdk:diff",
    "cdk:deploy": "pnpm -r --filter infra cdk:deploy",
    "all-commited": "git diff --exit-code && git diff --cached --exit-code",
    "prerelease": "npm-run-all2 --parallel typecheck lint test test:integration knip && pnpm run -w all-commited && echo 'All checks passed!'",
    "test:app": "vitest run --coverage --project app",
    "test:integration": "vitest run --coverage.enabled=false packages/integration-tests/tests"
  },
  "type": "module",
  "license": "BSD-3-Clause",
  "keywords": [],
  "author": {
    "name": "HRAshton"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "packageManager": "pnpm@10.34.4",
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "jiti": "catalog:",
    "knip": "catalog:",
    "npm-run-all2": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
