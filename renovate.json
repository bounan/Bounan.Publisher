{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "dependencyDashboard": true,
  "schedule": [
    "* 6 * * 6"
  ],
  "timezone": "UTC",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 3,
  "packageRules": [
    {
      "description": "Group and automerge updates that do not change a major version",
      "matchUpdateTypes": [
        "digest",
        "patch",
        "minor"
      ],
      "groupName": "all non-major dependencies",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "extends": [
      "schedule:weekly"
    ]
  }
}
